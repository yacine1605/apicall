import requests
import pandas as pd

BaseUrl='https://api.nasa.gov/neo/rest/v1/feed'
API_KEY = 'sUE74Xnrhs4qgDI6JK6p4NsTV3IW3oqlQwgK5icD'

params={
    'api_key' : API_KEY,
    'start_date':'2026-06-20',
    'end_date':'2026-06-21'
}
def GetInfo():
    getData = requests.get(BaseUrl,params)
    response = getData.json()
    
    liste = []
    
    for date, result in response['near_earth_objects'].items():
        
        for r in result:
            result_details = {
                'date': date,
                'ID': r['id'],
                'name': r['name'],
                'absolute_magnitude': r['absolute_magnitude_h'],
                'Relative_velocity': r['close_approach_data'][0]['relative_velocity']['kilometers_per_hour']
            }
        liste.append(result_details)
        res_df = pd.DataFrame(liste)
        print(res_df.head())

GetInfo()
